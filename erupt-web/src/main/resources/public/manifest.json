{
    "$schema": "https://json.schemastore.org/web-manifest-combined.json",
    "id": "/",
    "name": "Erupt",
    "short_name": "Erupt",
    "description": "Erupt Engine - a low-code framework that auto-generates admin UI from annotations.",
    "author": "YuePeng",
    "lang": "en",
    "dir": "ltr",
    "categories": ["business", "productivity", "developer"],
    "theme_color": "#05192c",
    "background_color": "#fafafa",
    "display": "standalone",
    "display_override": ["standalone", "minimal-ui", "browser"],
    "orientation": "any",
    "scope": "./",
    "start_url": "./",
    "icons": [
        {
            "src": "assets/icon.svg",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "any"
        },
        {
            "src": "assets/icon.svg",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "maskable"
        }
    ]
}
